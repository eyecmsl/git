FLASK_APP=run.py
# FLASK_ENV=production disables the debug reloader (avoids dual-process DB conflicts)
FLASK_ENV=production
RATELIMIT_ENABLED=false
SECRET_KEY=<generated-automatically-if-placeholder>
DATABASE_URL=sqlite:///tea.db
JWT_SECRET=<generated-automatically-if-placeholder>
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000
RP_ID=localhost
RP_NAME=Tea App
ORIGIN=http://localhost:3000
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=0x000000000000000000000000000000000000000
POW_DIFFICULTY=16
